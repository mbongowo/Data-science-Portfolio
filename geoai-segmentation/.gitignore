# pixi
.pixi/

# Data & model artifacts (versioned out-of-band, not in git).
# Ignore directory *contents* (not the dir itself) so .gitkeep / .gitignore
# placeholders stay tracked, and conf/data/ is not matched (leading slash).
/data/*
!/data/.gitkeep
/checkpoints/*
!/checkpoints/.gitignore
outputs/
mlruns/
*.ckpt
*.pth
*.tif
*.tiff

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
