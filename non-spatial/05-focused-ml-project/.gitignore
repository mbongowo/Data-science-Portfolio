# Secrets
.env

# Outputs (regenerated by the demo)
outputs/*
!outputs/.gitkeep

# Note: the bundled corpus/ is tracked on purpose so the app and demo run out of
# the box. User-supplied data is ignored via data/.gitignore (which is tracked),
# not a blanket data/ rule, so the directory and its .gitignore stay in the repo.

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/

# Tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.ipynb_checkpoints/

# Pixi / conda
.pixi/

# OS / editors
.DS_Store
Thumbs.db
.idea/
.vscode/
