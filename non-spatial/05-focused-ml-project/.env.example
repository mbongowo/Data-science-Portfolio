# Copy to .env and fill in ONLY if you want generated (LLM) answers. .env is
# gitignored — never commit real keys. The demo (python -m ragqa.cli demo), the
# extractive CLI and the default Streamlit app need NONE of these: extractive
# answers run free with no key.

# OpenAI provider
OPENAI_API_KEY=

# Azure OpenAI provider
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
