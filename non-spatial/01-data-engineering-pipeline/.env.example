# Copy to .env and fill in for the OPT-IN Azure path. .env is gitignored — never
# commit real values. The free local path (DuckDB) needs none of these.

# Azure subscription the Terraform module deploys into.
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000

# Azure SQL warehouse (the dbt `azure` profile reads these).
AZURE_SQL_SERVER=sql-cmr-weather-xxxxxx.database.windows.net
AZURE_SQL_DB=weather_dwh
AZURE_SQL_USER=weatheradmin
AZURE_SQL_PASSWORD=replace-with-a-strong-password

# ADLS Gen2 storage account that backs the cloud lake.
ADLS_ACCOUNT_NAME=stcmrweatherxxxxxx
