# Secrets / env
.env

# Data (downloaded lake + local warehouse; reproducible from the pipeline).
# data/.gitignore itself stays tracked (see that file).
*.duckdb

# Outputs (regenerated by the pipeline)
outputs/*
!outputs/.gitkeep

# Terraform
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
crash.log

# dbt artefacts (compiled SQL, packages, run logs)
transform/target/
transform/dbt_packages/
transform/logs/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/

# Tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.ipynb_checkpoints/

# OS / editors
.DS_Store
Thumbs.db
.idea/
.vscode/
