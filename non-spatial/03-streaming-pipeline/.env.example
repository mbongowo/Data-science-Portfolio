# Copy to .env and fill in. .env is gitignored — never commit real values. The
# free local demo (python -m aqstream.cli demo) needs none of these; they are for
# the live Kafka stack and the opt-in Azure path.

# Kafka broker(s) the producer/processor connect to (local docker-compose stack).
KAFKA_BROKERS=localhost:9092

# Webhook the notifier POSTs fired alerts to (a generic JSON or Slack incoming
# webhook). Leave blank to log alerts only.
ALERT_WEBHOOK_URL=

# Azure Event Hubs (Kafka-compatible) connection string for the OPT-IN Azure
# path. Only needed if you deploy the cloud broker — see azure/README.md.
AZURE_EVENTHUB_CONNECTION_STRING=
