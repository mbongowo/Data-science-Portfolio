*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/

# Tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.ipynb_checkpoints/

# Pixi / conda
.pixi/

# OS / editors
.DS_Store
Thumbs.db
.idea/
.vscode/
