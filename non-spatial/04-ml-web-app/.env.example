# Copy to .env and fill in if needed. .env is gitignored — never commit it.
# The demo (python -m croprec.cli demo) and the deployed app need NONE of these;
# the app trains on the bundled synthetic data and reads no secrets.

# Path to the real Kaggle Crop Recommendation CSV, for the optional stronger
# scikit-learn RandomForest path (python -m croprec.cli train --csv ...).
CROP_CSV_PATH=
