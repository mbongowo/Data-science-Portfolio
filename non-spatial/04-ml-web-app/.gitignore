# Secrets
.env

# Outputs (regenerated by the demo)
outputs/*
!outputs/.gitkeep

# Trained model binaries (the app trains the numpy model at runtime; the
# optional sklearn path writes here)
models/
*.pkl
*.joblib

# Note: downloaded data is ignored via data/.gitignore (which is tracked), not a
# blanket data/ rule, so the directory and its .gitignore stay in the repo. The
# bundled app/sample_data/ is tracked on purpose so the app runs out of the box.

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/

# Tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.ipynb_checkpoints/

# Pixi / conda
.pixi/

# OS / editors
.DS_Store
Thumbs.db
.idea/
.vscode/
