# Secrets
.env

# Data (provide your own; the demo synthesizes its own)
data/*
!data/.gitignore

# Outputs (regenerated by the demo / pipeline)
outputs/*
!outputs/.gitkeep

# MLflow tracking store and serialized models
mlruns/
models/
*.pkl
*.joblib

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/

# Tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.ipynb_checkpoints/

# Pixi (the lock is machine-generated; the env dir is local)
.pixi/

# OS / editors
.DS_Store
Thumbs.db
.idea/
.vscode/
