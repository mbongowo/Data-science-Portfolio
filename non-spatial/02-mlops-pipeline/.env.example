# Copy to .env and fill in as needed. .env is gitignored — never commit real
# values. The free local path (mlruns/ + the local FastAPI container) needs none
# of the Azure variables.

# MLflow tracking. Leave as the local folder for the free path; point at an Azure
# ML workspace MLflow tracking URI for the cloud path (see azure/README.md).
MLFLOW_TRACKING_URI=file:./mlruns

# Path the FastAPI service loads the pickled model from (mlpipe.serve / Docker).
MODEL_PATH=outputs/model.pkl

# Azure ML (OPT-IN, costs money). Only needed for the cloud tracking / serving
# path. Get these from `az ml workspace show`.
AZURE_ML_SUBSCRIPTION=00000000-0000-0000-0000-000000000000
AZURE_ML_RESOURCE_GROUP=rg-mlops-rainday
AZURE_ML_WORKSPACE=mlw-rainday
