# Copy to `.env` and fill in if needed. Never commit real secrets; `.env` is
# git-ignored. The dependency-free demo, the test suite, AND the EuroSAT
# download via TorchGeo need NONE of these — EuroSAT is a public dataset that
# TorchGeo fetches automatically.

# Optional: override where TorchGeo caches the EuroSAT download (defaults to
# data/eurosat). Useful on Colab to point at a mounted Drive folder.
EUROSAT_DATA_ROOT=data/eurosat

# Optional: force the training device. Auto-detected (cuda if available) when
# unset. Set to "cpu" to run the heavy path without a GPU (slow).
LCNET_DEVICE=
