# Copy to `.env` and fill in. Never commit real secrets. The `.env` file is
# git-ignored. The dependency-free demo, the test suite, AND the default STAC
# data path need NONE of these — STAC (Earth Search Sentinel-1 GRD) is auth-free.

# Optional: AWS region for the Earth Search S3-hosted assets. Only relevant if
# you tune the odc-stac / rasterio GDAL settings for the COG reads; the default
# anonymous access needs no credentials.
AWS_DEFAULT_REGION=us-west-2
