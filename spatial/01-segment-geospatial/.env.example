# Copy to `.env` and fill in. Never commit real secrets. The `.env` file is
# git-ignored. The dependency-free demo and the test suite need NONE of these.

# Optional Mapbox token, only if you switch the basemap source to a Mapbox
# tile service in config/aoi.yaml. The default "Satellite" source does not
# require a token.
MAPBOX_TOKEN=your-mapbox-token-here

# Optional path to a pre-downloaded SAM checkpoint. If unset, samgeo downloads
# the default model on first use.
SAM_CHECKPOINT=
