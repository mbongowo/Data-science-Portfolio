# Reproducible runtime via pixi. The lockfile (pixi.lock) is generated by
# `pixi install`; commit it for byte-for-byte reproducible Docker builds.
FROM ghcr.io/prefix-dev/pixi:latest

WORKDIR /app

# Resolve the environment first (better layer caching). pixi.lock is optional
# pre-resolution; if present it pins exact versions.
COPY pixi.toml pyproject.toml ./
COPY pixi.lock* ./
RUN pixi install --locked || pixi install

# Project source
COPY src/ ./src/
COPY conf/ ./conf/
COPY scripts/ ./scripts/
COPY tests/ ./tests/
COPY README.md MODEL_CARD.md ./

# Default: run the pure-numpy tests as a cheap healthcheck.
CMD ["pixi", "run", "test"]
