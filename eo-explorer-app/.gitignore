# Streamlit
.streamlit/secrets.toml

# Data -- fetched live, never committed
data/
*.tif
*.tiff
*.nc
*.zarr/
*.geojson

# Notebook checkpoints
.ipynb_checkpoints/

# OS / editor
.DS_Store
Thumbs.db
