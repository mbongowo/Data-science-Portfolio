# Data (downloaded, large, reproducible from data/download.py)
data/raw/*
!data/raw/.gitignore

# Outputs (regenerated by the pipeline)
outputs/*
!outputs/.gitkeep

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/

# Tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.ipynb_checkpoints/

# Pixi (the lock is machine-generated; the env dir is local)
.pixi/

# OS / editors
.DS_Store
Thumbs.db
.idea/
.vscode/

# Notebook-run demo artifacts
notebooks/outputs/
